<root>
	<styles>
		<include src="s2r://panorama/styles/dotastyles.vcss_c" />
		<include src="file://{resources}/layout/custom_game/craft6panel/craft6panel.css" />
	</styles>
	<scripts>
		<include src="file://{resources}/layout/custom_game/craft6panel/craft6panel.js" />
	</scripts>

	<Panel class="Craft6PanelRoot">
		<Panel id="Craft6OpenWrap">
			<Button id="Craft6OpenButton" onactivate="ToggleCraft6Panel()">
				<Image id="Craft6OpenIcon" src="s2r://panorama/images/custom_game/all/buttonrelic.png"/>
				<Label id="Craft6OpenText" text="КРАФТ"/>
			</Button>
		</Panel>

		<Panel id="Craft6Window" class="Craft6WindowHidden">
			<Panel id="Craft6Header">
				<Label id="Craft6HeaderTitle" text="УЛУЧШЕННЫЙ КРАФТ" />
				<Button id="Craft6CloseButton" onactivate="ToggleCraft6Panel()">
					<Label id="Craft6CloseButtonLabel" text="✕" />
				</Button>
			</Panel>

			<Panel id="Craft6Body">
				<Panel id="Craft6RecipeList" />
			</Panel>
		</Panel>
	</Panel>
</root>