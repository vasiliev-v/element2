<root>
	<styles>
		<include src="s2r://panorama/styles/dotastyles.vcss_c" />
		<include src="s2r://panorama/styles/custom_game/elementshop.css" />
	</styles>
	<scripts>
		<include src="s2r://panorama/scripts/custom_game/elementshop.js" />
	</scripts>

	<Panel hittest="false" class="ElementShopPanel">
		<Panel hittest="false" id="ShopRoot">
			
			<Panel hittest="false" id="ShopInfo" class="ShopInfoAnim ShopInfoStyled">
				<Panel class="ShopInfoHeader">
					<Label class="ShopTitle" text="#elements" />
					<Button id="ToggleX3mode" class="TopRoundButton" onactivate="ToggleX3mode()"
						onmouseover="DOTAShowTextTooltip('x3 mode')"
						onmouseout="DOTAHideTextTooltip()">
						<Image hittest="false" src="s2r://panorama/images/custom_game/all/x3.png" class="TopRoundButtonIcon" />
					</Button>
				</Panel>

				<Panel class="ShopInfoColumns">
					<Panel class="ShopInfoDivider" />
					<Panel class="ShopInfoDivider ShopInfoDivider2" />
				</Panel>

				<Button id="OffInfo" class="SideHideButton" onactivate="OffInfo()">
					<Label text="‹" />
				</Button>
			</Panel>

			<Panel hittest="false" id="Shop" class="ShopStyled">
				<Panel class="ShopLeftHeader">
					<Label class="ShopLeftTitle" text="#elements" />
				</Panel>

				<Label hittest="false" id="lvlmyitemtext1" text="x 0" class="ElementCountLabel count1" />
				<Label hittest="false" id="lvlmyitemtext2" text="x 0" class="ElementCountLabel count2" />
				<Label hittest="false" id="lvlmyitemtext3" text="x 0" class="ElementCountLabel count3" />
				<Label hittest="false" id="lvlmyitemtext4" text="x 0" class="ElementCountLabel count4" />
				<Label hittest="false" id="lvlmyitemtext5" text="x 0" class="ElementCountLabel count5" />
				<Label hittest="false" id="lvlmyitemtext6" text="x 0" class="ElementCountLabel count6" />
				<Label hittest="false" id="lvlmyitemtext7" text="x 0" class="ElementCountLabel count7" />
				<Label hittest="false" id="lvlmyitemtext8" text="x 0" class="ElementCountLabel count8" />
				<Label hittest="false" id="lvlmyitemtext9" text="x 0" class="ElementCountLabel count9" />
				<Label hittest="false" id="lvlmyitemtext10" text="x 0" class="ElementCountLabel count10" />

				<DOTAItemImage id="myitem1" itemname="item_ice" class="BaseElementSlot slot1" onactivate="Buy(1)" />
				<DOTAItemImage id="myitem2" itemname="item_fire" class="BaseElementSlot slot2" onactivate="Buy(2)" />
				<DOTAItemImage id="myitem3" itemname="item_water" class="BaseElementSlot slot3" onactivate="Buy(3)" />
				<DOTAItemImage id="myitem4" itemname="item_energy" class="BaseElementSlot slot4" onactivate="Buy(4)" />
				<DOTAItemImage id="myitem5" itemname="item_earth" class="BaseElementSlot slot5" onactivate="Buy(5)" />
				<DOTAItemImage id="myitem6" itemname="item_life" class="BaseElementSlot slot6" onactivate="Buy(6)" />
				<DOTAItemImage id="myitem7" itemname="item_void" class="BaseElementSlot slot7" onactivate="Buy(7)" />
				<DOTAItemImage id="myitem8" itemname="item_air" class="BaseElementSlot slot8" onactivate="Buy(8)" />
				<DOTAItemImage id="myitem9" itemname="item_light" class="BaseElementSlot slot9" onactivate="Buy(9)" />
				<DOTAItemImage id="myitem10" itemname="item_shadow" class="BaseElementSlot slot10" onactivate="Buy(10)" />

				<Button id="OnInfo" class="SideShowButton" onactivate="OnInfo()">
					<Label text="›" />
				</Button>
			</Panel>

			<Panel hittest="false" id="ElementShop" class="ElementShopButtonWrap">
				<Button id="Vote_Yes" class="ElementOpenButton" onactivate="Open()">
                    <Image id="yes_button" src="s2r://panorama/images/custom_game/all/buttonrelic.png" class="ElementOpenButtonIcon"/>
                    <Label id="ElementButtonText" text="ЭЛЕМЕНТЫ"/>
                </Button>
				<Label hittest="false" id="readytext" class="ElementShopText" text="#elements"/>
			</Panel>
		</Panel>
	</Panel>
</root>