<root>
    <styles>
 		<include src="s2r://panorama/styles/dotastyles.vcss_c" />
        <include src="file://{resources}/layout/custom_game/multiteam_end_screen/multiteam_end_screen.css" />
    </styles>
    <scripts>
		<include src="file://{resources}/layout/custom_game/scripts/util.js" />
        <include src="file://{resources}/layout/custom_game/scripts/shared_scoreboard_updater.js" />
        <include src="file://{resources}/layout/custom_game/multiteam_end_screen/multiteam_end_screen.js" />
    </scripts>
	<Panel hittest="false" class="EndScreenRoot">
		<Panel id="VictoryRow">
			<Label id="EndScreenVictory" />
		</Panel>

		<Panel hittest="false" class="EndScreenWindow">
			<Panel class="Legend">
				<Label class="LegendPanel NewStyleScore_Deaths" text="#custom_end_screen_legend_deaths" />
				<Label class="LegendPanel NewStyleScore_LastHits" text="LH" />
				<Label class="LegendPanel NewStyleScore_Items" text="Items / Backpack / Neutral" />
			</Panel>

			<Panel id="TeamsContainer" />

			<Button id="CloseButton" onactivate="Game.FinishGame();">
				<Label text="#CustomEndScreenClose" />
			</Button>

			<Panel id="ActiveButtons">
				<Panel class="ActiveButton" id="Button_1" onactivate="ExternalBrowserGoToURL('https://tve-shop.com');">
					<Label class="ActiveButton_text" text="TvE Shop" />
				</Panel>
				<Panel class="ActiveButton" id="Button_2" onactivate="ExternalBrowserGoToURL('https://paypal.com/paypalme/vasyliev95');">
					<Label class="ActiveButton_text" text="PayPal" />
				</Panel>
			</Panel>
		</Panel>
	</Panel>
</root>