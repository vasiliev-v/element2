<root>
	<styles>
		<include src="s2r://panorama/styles/dotastyles.vcss_c" />
		<include src="s2r://panorama/styles/custom_game/roundoptions.css" />
	</styles>
	<scripts>
		<include src="s2r://panorama/scripts/custom_game/roundoptions.js" />
	</scripts>
    
	<Panel hittest="false" class="RoundOptionsPanel">
		<Panel hittest="false" id="RoundOptions">

			<Panel id="RoundOptionsHeader">
				<Label hittest="false" id="question" text="#votetext"/>
			</Panel>

			<Panel id="VoteHeroesRow">
				<Panel class="VoteHeroCard" style="margin-left:17px;">
					<Panel class="VoteHeroFrame"/>
					<DOTAHeroImage id="hero1" heroname="" class="VoteHeroImage"/>
					<Image id="hero1_yes" class="VoteHeroMark" src="s2r://panorama/images/custom_game/all/yes.png"/>
					<Image id="hero1_no" class="VoteHeroMark" src="s2r://panorama/images/custom_game/all/no.png"/>
				</Panel>

				<Panel class="VoteHeroCard" style="margin-left:107px;">
					<Panel class="VoteHeroFrame"/>
					<DOTAHeroImage id="hero2" heroname="" class="VoteHeroImage"/>
					<Image id="hero2_yes" class="VoteHeroMark" src="s2r://panorama/images/custom_game/all/yes.png"/>
					<Image id="hero2_no" class="VoteHeroMark" src="s2r://panorama/images/custom_game/all/no.png"/>
				</Panel>

				<Panel class="VoteHeroCard" style="margin-left:197px;">
					<Panel class="VoteHeroFrame"/>
					<DOTAHeroImage id="hero3" heroname="" class="VoteHeroImage"/>
					<Image id="hero3_yes" class="VoteHeroMark" src="s2r://panorama/images/custom_game/all/yes.png"/>
					<Image id="hero3_no" class="VoteHeroMark" src="s2r://panorama/images/custom_game/all/no.png"/>
				</Panel>

				<Panel class="VoteHeroCard" style="margin-left:287px;">
					<Panel class="VoteHeroFrame"/>
					<DOTAHeroImage id="hero4" heroname="" class="VoteHeroImage"/>
					<Image id="hero4_yes" class="VoteHeroMark" src="s2r://panorama/images/custom_game/all/yes.png"/>
					<Image id="hero4_no" class="VoteHeroMark" src="s2r://panorama/images/custom_game/all/no.png"/>
				</Panel>

				<Panel class="VoteHeroCard" style="margin-left:377px;">
					<Panel class="VoteHeroFrame"/>
					<DOTAHeroImage id="hero5" heroname="" class="VoteHeroImage"/>
					<Image id="hero5_yes" class="VoteHeroMark" src="s2r://panorama/images/custom_game/all/yes.png"/>
					<Image id="hero5_no" class="VoteHeroMark" src="s2r://panorama/images/custom_game/all/no.png"/>
				</Panel>
			</Panel>

			<Label hittest="false" id="confirmation" text="#voteyestext"/>

			<Button id="Vote_Yes" onactivate="Yes()">
				<Image id="yes_button" src="s2r://panorama/images/custom_game/all/button.png"/>
				<Label id="VoteButtonText" text="#ready"/>
			</Button>

            <ToggleButton id="Auto_Vote" text="Auto Vote" onactivate="Toggle()" />
            <Label hittest="false" id="readytext"/>
		</Panel>
	</Panel>
</root>