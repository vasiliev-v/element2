<root>
    <styles>
        <include src="s2r://panorama/styles/dotastyles.vcss_c" />
        <include src="s2r://panorama/styles/custom_game/multiteam_flyout_scoreboard.css" />
    </styles>

    <scripts>
        <include src="file://{resources}/scripts/custom_game/shared_scoreboard_updater.js" />
        <include src="file://{resources}/scripts/custom_game/multiteam_flyout_scoreboard.js" />
    </scripts>

    <Panel hittest="false" class="FlyoutScoreboardRoot">
        <Panel class="Legend">
            <Panel class="LegendPanel ScoreCol_TeamInfo" />
            <Panel class="LegendPanel ScoreCol_Hero" />
            <Panel class="LegendPanel ScoreCol_PlayerDetails" />
            <Panel class="LegendPanel ScoreCol_TeamScore" />
            <Label class="LegendPanel ScoreCol_Kills" text="#DOTA_Scoreboard_Kills" />
            <Label class="LegendPanel ScoreCol_Deaths" text="#DOTA_Scoreboard_Deaths" />
            <Label class="LegendPanel ScoreCol_Assists" text="#DOTA_Scoreboard_Assists" />
        </Panel>
        <Panel id="TeamsContainer" />
    </Panel>
</root>
